<ui:FluentWindow x:Class="DiagCore.App.Views.WelcomeWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:c="clr-namespace:DiagCore.App.Controls"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:DiagCore.App.ViewModels"
                 mc:Ignorable="d"
                 Title="Bienvenido a DiagCore"
                 Icon="pack://application:,,,/Assets/logo.png"
                 Width="720"
                 Height="640"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Default"
                 WindowStartupLocation="CenterScreen"
                 ShowInTaskbar="False"
                 d:DataContext="{d:DesignInstance Type=vm:WelcomeViewModel}">

    <Grid Background="{DynamicResource BgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Custom mini chrome: brand label on the left, close button on the right.  -->
        <Grid Grid.Row="0" Background="{DynamicResource BgSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource UiFontFamily}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Text="Bienvenido a DiagCore" />
            <Button Grid.Column="1"
                    Click="OnCloseClick"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Style="{StaticResource WindowControlCloseButtonStyle}"
                    ToolTip="Cerrar">
                <ui:SymbolIcon FontSize="12" Symbol="Dismiss24" />
            </Button>
        </Grid>

        <!--  Main scrollable content  -->
        <ScrollViewer Grid.Row="1"
                      Padding="32,16,32,16"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Header  -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,20">
                    <Image Width="96"
                           Height="96"
                           Source="pack://application:,,,/Assets/logo.png" />
                    <TextBlock Margin="0,16,0,0"
                               HorizontalAlignment="Center"
                               FontFamily="{StaticResource DisplayFontFamily}"
                               FontSize="32"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Text="DiagCore" />
                    <Border Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            Padding="10,3"
                            Background="{DynamicResource AccentSoftBrush}"
                            CornerRadius="6">
                        <TextBlock FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding AppVersion}" />
                    </Border>
                    <TextBlock Margin="0,12,0,0"
                               MaxWidth="520"
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="Diagnóstico técnico para Windows. Sin telemetría, sin cuentas, sin nada saliendo de tu equipo. Reemplaza una caja de comandos manuales por una sola herramienta." />
                </StackPanel>

                <!--  Credits  -->
                <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="56"
                                Height="56"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="28">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource DisplayFontFamily}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="RM" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource UiFontFamily}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Text="CREADOR" />
                            <TextBlock Margin="0,2,0,0"
                                       FontFamily="{StaticResource DisplayFontFamily}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="{Binding AuthorFullName}" />
                            <TextBlock Margin="0,2,0,0"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                <Run Text="@" />
                                <Run Text="{Binding AuthorHandle, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Text="{Binding AuthorTagline}" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                VerticalAlignment="Center"
                                Command="{Binding OpenRepositoryCommand}"
                                Style="{StaticResource ButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon FontSize="14" VerticalAlignment="Center" Symbol="Open24" />
                                <TextBlock Margin="8,0,0,0" Text="GitHub" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!--  Changelog  -->
                <Border Margin="0,0,0,12" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12" Orientation="Horizontal">
                            <ui:SymbolIcon VerticalAlignment="Center"
                                           FontSize="18"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Symbol="History24" />
                            <TextBlock Margin="8,0,0,0" Style="{StaticResource CardTitleStyle}" Text="Novedades" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ChangelogEntry}">
                                    <StackPanel Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}">
                                                <Run Text="v" />
                                                <Run Text="{Binding Version, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Text="{Binding Date, StringFormat='{}{0:dd MMM yyyy}'}" />
                                        </StackPanel>
                                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Changes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0"
                                                                 Width="5"
                                                                 Height="5"
                                                                 Margin="0,7,10,0"
                                                                 VerticalAlignment="Top"
                                                                 Fill="{DynamicResource AccentBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding}"
                                                                   TextWrapping="Wrap" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--  Privacy  -->
                <Border Margin="0,0,0,12"
                        Padding="14,12"
                        Background="{DynamicResource BgSecondaryBrush}"
                        BorderBrush="{DynamicResource OkBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                            <ui:SymbolIcon VerticalAlignment="Center"
                                           FontSize="16"
                                           Foreground="{DynamicResource OkBrush}"
                                           Symbol="LockClosed24" />
                            <TextBlock Margin="8,0,0,0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="Privacidad" />
                        </StackPanel>
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap">
                            <Run Text="• Cero telemetría. Cero cuentas. Cero datos enviados a servidores del autor." />
                            <LineBreak />
                            <Run Text="• Los informes y el histórico se quedan en tu equipo." />
                            <LineBreak />
                            <Run Text="• Única llamada saliente: api.ipify.org, y solo si pulsas 'Consultar IP pública' manualmente." />
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  Footer  -->
        <Border Grid.Row="2"
                Padding="32,14,32,18"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0"
                          VerticalAlignment="Center"
                          Content="No volver a mostrar al iniciar"
                          FontFamily="{StaticResource UiFontFamily}"
                          FontSize="13"
                          Foreground="{DynamicResource TextSecondaryBrush}"
                          IsChecked="{Binding SuppressWelcomeOnStartup, Mode=TwoWay}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Margin="0,0,8,0"
                            Command="{Binding OpenIssuesCommand}"
                            Style="{StaticResource ButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon FontSize="14" VerticalAlignment="Center" Symbol="Bug24" />
                            <TextBlock Margin="8,0,0,0" Text="Issues" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ContinueButton"
                            Click="OnContinueClick"
                            Style="{StaticResource PrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,8,0" Text="Empezar" />
                            <ui:SymbolIcon FontSize="14" VerticalAlignment="Center" Symbol="ArrowRight24" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>

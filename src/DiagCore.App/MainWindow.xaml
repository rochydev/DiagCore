<ui:FluentWindow x:Class="DiagCore.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:v="clr-namespace:DiagCore.App.Views"
                 xmlns:vm="clr-namespace:DiagCore.App.ViewModels"
                 mc:Ignorable="d"
                 Title="{Binding Title}"
                 Icon="pack://application:,,,/Assets/logo.png"
                 Width="1280"
                 Height="800"
                 MinWidth="960"
                 MinHeight="600"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Default"
                 WindowStartupLocation="CenterScreen"
                 d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}">

    <ui:FluentWindow.Resources>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <v:PlaceholderView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <v:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HardwareViewModel}">
            <v:HardwareView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StorageViewModel}">
            <v:StorageView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkViewModel}">
            <v:NetworkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SecurityViewModel}">
            <v:SecurityView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <v:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView />
        </DataTemplate>

        <!--
            Single ItemContainerStyle for the unified sidebar. The DataTrigger
            keeps the Settings item docked at the bottom of the panel.
        -->
        <Style x:Key="SidebarNavItemDockedStyle"
               TargetType="{x:Type ListBoxItem}"
               BasedOn="{StaticResource SidebarNavItemStyle}">
            <Setter Property="DockPanel.Dock" Value="Top" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFooter}" Value="True">
                    <Setter Property="DockPanel.Dock" Value="Bottom" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource BgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Logo block (60x64, aligned with the sidebar column)  -->
        <Border Grid.Row="0"
                Grid.Column="0"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,1">
            <Image Width="52"
                   Height="52"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Source="pack://application:,,,/Assets/logo.png" />
        </Border>

        <!--  Drag area + window controls  -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Empty drag area (no brand text - the logo already conveys the identity).  -->

                <!--  Window control buttons  -->
                <StackPanel Grid.Column="1"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Orientation="Horizontal">
                    <Button x:Name="MinimizeButton"
                            Click="OnMinimizeClick"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Minimizar">
                        <ui:SymbolIcon FontSize="12" Symbol="Subtract24" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Click="OnMaximizeRestoreClick"
                            Style="{StaticResource WindowControlButtonStyle}"
                            ToolTip="Maximizar">
                        <ui:SymbolIcon x:Name="MaximizeIcon" FontSize="12" Symbol="Square24" />
                    </Button>
                    <Button x:Name="CloseButton"
                            Click="OnCloseClick"
                            Style="{StaticResource WindowControlCloseButtonStyle}"
                            ToolTip="Cerrar">
                        <ui:SymbolIcon FontSize="12" Symbol="Dismiss24" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--
            Sidebar - single ListBox so there is exactly one SelectedItem
            across the whole navigation surface. The DockPanel + DataTrigger
            on ListBoxItem.Dock keeps the Settings entry anchored to the
            bottom while the other entries stack from the top.
        -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="{DynamicResource BgPrimaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <ListBox Margin="0,8"
                     IsSynchronizedWithCurrentItem="False"
                     ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                     ItemContainerStyle="{StaticResource SidebarNavItemDockedStyle}"
                     Style="{StaticResource ChromelessListBoxStyle}">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <DockPanel LastChildFill="False" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NavigationItem}">
                        <Grid ToolTip="{Binding Title}">
                            <ui:SymbolIcon HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="20"
                                           Symbol="{Binding Icon}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!--
            Content area. The hosted view is responsible for its own entrance
            animation (PlaceholderView / HardwareView / ... fade + slide-in
            8px on Loaded).
        -->
        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        Content="{Binding SelectedItem.Content}"
                        Focusable="False" />

        <!--  StatusBar with accent-coloured version pill  -->
        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="{DynamicResource BgSecondaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel VerticalAlignment="Center"
                        Margin="12,0"
                        Orientation="Horizontal">
                <Border Padding="6,1"
                        VerticalAlignment="Center"
                        Background="{DynamicResource AccentSoftBrush}"
                        CornerRadius="4">
                    <TextBlock FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding AppVersionDisplay}" />
                </Border>
                <TextBlock Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="{StaticResource UiFontFamily}"
                           FontSize="11"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Text="{Binding FooterCredit}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>

<UserControl x:Class="DiagCore.App.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             d:DesignWidth="100"
             mc:Ignorable="d">

    <Border x:Name="BadgeBorder"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Padding="8,3"
            Background="{Binding BackgroundBrush, ElementName=Root}"
            CornerRadius="6">
        <StackPanel Orientation="Horizontal">
            <Ellipse Width="6"
                     Height="6"
                     VerticalAlignment="Center"
                     Fill="{Binding ForegroundBrush, ElementName=Root}" />
            <TextBlock Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource UiFontFamily}"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{Binding ForegroundBrush, ElementName=Root}"
                       Text="{Binding Text, ElementName=Root}" />
        </StackPanel>
    </Border>
</UserControl>

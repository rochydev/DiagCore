<UserControl x:Class="DiagCore.App.Controls.KeyValueRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             d:DesignWidth="400"
             mc:Ignorable="d">

    <Grid Margin="0,3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   VerticalAlignment="Top"
                   FontFamily="{StaticResource UiFontFamily}"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="{Binding Label, ElementName=Root}" />

        <TextBlock Grid.Column="1"
                   VerticalAlignment="Top"
                   FontFamily="{Binding ValueFontFamily, ElementName=Root}"
                   FontSize="13"
                   FontWeight="Medium"
                   Foreground="{Binding ValueForeground, ElementName=Root}"
                   Text="{Binding Value, ElementName=Root}"
                   TextWrapping="Wrap" />
    </Grid>
</UserControl>

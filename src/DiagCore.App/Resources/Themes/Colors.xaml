<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Backgrounds  -->
    <Color x:Key="BgPrimaryColor">#FF0F1115</Color>
    <Color x:Key="BgSecondaryColor">#FF161922</Color>
    <Color x:Key="BgTertiaryColor">#FF1E2230</Color>
    <Color x:Key="BgElevatedColor">#FF232838</Color>

    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="BgSecondaryBrush" Color="{StaticResource BgSecondaryColor}" />
    <SolidColorBrush x:Key="BgTertiaryBrush" Color="{StaticResource BgTertiaryColor}" />
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedColor}" />

    <!--  Accent (primary blue)  -->
    <Color x:Key="AccentColor">#FF3B82F6</Color>
    <Color x:Key="AccentHoverColor">#FF2563EB</Color>
    <Color x:Key="AccentSoftColor">#1F3B82F6</Color>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />

    <!--  Semantic states  -->
    <Color x:Key="OkColor">#FF10B981</Color>
    <Color x:Key="WarningColor">#FFF59E0B</Color>
    <Color x:Key="DangerColor">#FFEF4444</Color>
    <Color x:Key="InfoColor">#FF06B6D4</Color>

    <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <!--  Text  -->
    <Color x:Key="TextPrimaryColor">#FFE5E7EB</Color>
    <Color x:Key="TextSecondaryColor">#FF9CA3AF</Color>
    <Color x:Key="TextMutedColor">#FF6B7280</Color>
    <Color x:Key="TextDisabledColor">#FF4B5563</Color>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}" />

    <!--  Borders  -->
    <Color x:Key="BorderColor">#FF2A2F3F</Color>
    <Color x:Key="BorderStrongColor">#FF3A4055</Color>
    <Color x:Key="BorderFocusColor">#FF3B82F6</Color>

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}" />

    <!--  Override of selected WPF-UI brushes so the rest of the toolkit picks up our palette  -->
    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="{StaticResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="ControlElevationBorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush" Color="{StaticResource BgSecondaryColor}" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush" Color="{StaticResource BgTertiaryColor}" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush" Color="{StaticResource BgElevatedColor}" />

    <Color x:Key="SystemAccentColor">#FF3B82F6</Color>
    <Color x:Key="SystemAccentColorPrimary">#FF2563EB</Color>
    <SolidColorBrush x:Key="SystemAccentColorPrimaryBrush" Color="{StaticResource SystemAccentColorPrimary}" />
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource AccentHoverColor}" />

</ResourceDictionary>

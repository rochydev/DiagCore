<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!--
        Variable font: WPF resolves the wght axis from FontWeight set on the consumer.
        Fallbacks: Segoe UI Variable Display (Win11), Segoe UI (Win10).
    -->
    <FontFamily x:Key="DisplayFontFamily">pack://application:,,,/Resources/Fonts/#Inter, Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="UiFontFamily">pack://application:,,,/Resources/Fonts/#Inter, Segoe UI Variable, Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFontFamily">pack://application:,,,/Resources/Fonts/#JetBrains Mono, Cascadia Mono, Consolas</FontFamily>

    <!--  Type scale (px): 12 / 13 / 14 / 16 / 20 / 28  -->
    <sys:Double x:Key="FontSize.Caption">12</sys:Double>
    <sys:Double x:Key="FontSize.BodySmall">13</sys:Double>
    <sys:Double x:Key="FontSize.Body">14</sys:Double>
    <sys:Double x:Key="FontSize.Subtitle">16</sys:Double>
    <sys:Double x:Key="FontSize.Title">20</sys:Double>
    <sys:Double x:Key="FontSize.Display">28</sys:Double>

    <!--  Default TextBlock (no x:Key, applies to every TextBlock unless overridden)  -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="DisplayTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Display}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="TitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="SubtitleTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Subtitle}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.BodySmall}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource UiFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.Caption}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <Style x:Key="MonoTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.BodySmall}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

</ResourceDictionary>
